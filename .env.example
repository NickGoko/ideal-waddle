# Copy this file to `.env` and adjust as needed:  cp .env.example .env
# Read by both the Prisma CLI and Next.js. Never commit the real `.env`.

# SQLite database. Path is resolved relative to prisma/schema.prisma,
# so "file:./dev.db" lives at prisma/dev.db.
DATABASE_URL="file:./dev.db"

# DEMO_MODE: no real auth, role switcher in the UI, external integrations mocked.
DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"

# Absolute app URL used by the server-side cron initializer in app/layout.tsx.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: real Slack alerts in DEMO_MODE. If unset, alerts log to the console.
# SLACK_WEBHOOK_URL=""
